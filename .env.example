# Copy this file to .env.local and fill in your values

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=

# Supabase — get from your project's Settings > API in supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # used only by scripts/seed.ts — never expose to the browser
